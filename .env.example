# Sotuvchi Trainer — muhit o'zgaruvchilari namunasi.
# Nusxa ol: cp .env.example .env.local  va qiymatlarni to'ldir.
# .env.local hech qachon commit qilinmaydi (qara: .gitignore, CLAUDE.md §3).

# --- Aisha.ai (o'zbek STT/TTS) — SERVER ONLY ---
AISHA_API_KEY=
# MAJBURIY — Aisha dashboard/hujjatidan olingan HAQIQIY API manzili.
# Kod hech qanday manzilni o'zi taxmin qilmaydi (xavfsizlik uchun ataylab).
AISHA_BASE_URL=
# Quyidagilar IXTIYORIY — faqat akkauntingiz endpoint yo'li/auth'i standart
# taxmindan farq qilsa to'ldiring (src/lib/aisha.ts izohiga qarang):
AISHA_STT_PATH=        # standart: /api/v1/stt
AISHA_TTS_PATH=        # standart: /api/v1/tts
AISHA_AUTH_SCHEME=     # "raw" (Authorization: <key>) yoki "bearer"; standart: raw
AISHA_TTS_VOICE=       # standart ovoz identifikatori (bo'lsa)

# --- OpenAI (persona + baholovchi) — SERVER ONLY ---
OPENAI_API_KEY=
# Model IDsi (ixtiyoriy; sozlanmasa "gpt-4o-mini" ishlatiladi; sifat uchun "gpt-4o")
OPENAI_MODEL=

# --- Supabase ---
# Public URL brauzerga chiqadi (NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
# Anon key — brauzer klient uchun (RLS bilan himoyalangan)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service key — FAQAT server, hech qachon brauzerga chiqmaydi
SUPABASE_SERVICE_KEY=

# --- Payme (subscription — keyingi bosqichlar) — SERVER ONLY ---
PAYME_MERCHANT_ID=
PAYME_KEY=

# --- Click (subscription — keyingi bosqichlar) — SERVER ONLY ---
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# --- Dev/bench (ixtiyoriy) ---
# scripts/bench-voice.mjs uchun bazaviy URL (sozlanmasa http://localhost:3000)
BENCH_BASE_URL=

# --- SEO (ixtiyoriy) ---
# sitemap.ts uchun kanonik public URL (sozlanmasa http://localhost:3000)
NEXT_PUBLIC_SITE_URL=
