# Sotuvchi Trainer — muhit o'zgaruvchilari namunasi.
# Nusxa ol: cp .env.example .env.local va qiymatlarni to'ldir.
# .env.local hech qachon commit qilinmaydi (qara: .gitignore, CLAUDE.md §3).

# --- Aisha.ai (o'zbek STT/TTS, mo.aisha.group) — SERVER ONLY ---
AISHA_API_KEY=

# --- Anthropic Claude (persona + baholovchi) — SERVER ONLY ---
ANTHROPIC_API_KEY=
# Model IDsi (ixtiyoriy; sozlanmasa "claude-sonnet-4-5" ishlatiladi)
ANTHROPIC_MODEL=

# --- Auth + DB (self-hosted, Contabo) — SERVER ONLY ---
# PostgreSQL ulanish satri (o'z serveringizdagi Postgres).
# Masalan: postgres://user:parol@127.0.0.1:5432/sotibkor
DATABASE_URL=
# Masofaviy DB uchun TLS kerak bo'lsa: PGSSL=require
PGSSL=
# Pool hajmi (ixtiyoriy, default 10)
PG_POOL_MAX=
# JWT sessiya siri — MAJBURIY, kamida 16 belgi, tasodifiy.
# Yaratish: openssl rand -base64 48
JWT_SECRET=

# --- Supabase (ixtiyoriy / eski) ---
# Self-hosted DB ishlatilsa SHART EMAS. Faqat Supabase adapteri kerak bo'lsa.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Payme (subscription — keyingi bosqichlar) — SERVER ONLY ---
PAYME_MERCHANT_ID=
PAYME_KEY=

# --- Click (subscription — keyingi bosqichlar) — SERVER ONLY ---
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# --- Dev/bench (ixtiyoriy) ---
# scripts/bench-voice.mjs uchun bazaviy URL (sozlanmasa http://localhost:3000)
BENCH_BASE_URL=
